<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="welcome">
      <text class="title">超级助理</text>
      <text class="subtitle">您的顶级领导助理</text>
    </view>
  </view>
  
  <!-- 功能卡片 -->
  <view class="card-container">
    <view class="card" bindtap="navigateToChat">
      <text class="card-icon">💬</text>
      <text class="card-title">智能对话</text>
      <text class="card-desc">随时为您提供支持</text>
    </view>
    
    <view class="card" bindtap="navigateToSchedule">
      <text class="card-icon">📅</text>
      <text class="card-title">日程管理</text>
      <text class="card-desc">智能安排您的行程</text>
    </view>
    
    <view class="card" bindtap="navigateToEmotion">
      <text class="card-icon">💝</text>
      <text class="card-title">情绪关怀</text>
      <text class="card-desc">为您提供情绪价值</text>
    </view>
  </view>
  
  <!-- 今日概览 -->
  <view class="section">
    <text class="section-title">今日概览</text>
    <view class="overview">
      <view class="overview-item">
        <text class="value">{{todayTasks.length}}</text>
        <text class="label">今日待办</text>
      </view>
      <view class="overview-item">
        <text class="value">{{mood}}</text>
        <text class="label">情绪状态</text>
      </view>
      <view class="overview-item">
        <text class="value">{{efficiency}}%</text>
        <text class="label">完成率</text>
      </view>
    </view>
  </view>
</view>