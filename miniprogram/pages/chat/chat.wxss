/* pages/chat/chat.wxss */
.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.message-list {
  flex: 1;
  padding: 20rpx;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.message-content {
  max-width: 70%;
  padding: 20rpx;
  border-radius: 20rpx;
  margin: 0 20rpx;
}

.message-content.assistant {
  background: #f0f4ff;
}

.message-content.user {
  background: #667eea;
  color: white;
}

.time {
  font-size: 20rpx;
  opacity: 0.7;
  display: block;
  margin-top: 10rpx;
}

.quick-replies {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 15rpx;
}

.quick-reply {
  background: #f0f4ff;
  padding: 15rpx 25rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  color: #667eea;
}

.input-area {
  display: flex;
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  border: 1rpx solid #ddd;
  border-radius: 25rpx;
  padding: 15rpx 25rpx;
  margin-right: 20rpx;
}

.send-btn {
  background: #667eea;
  color: white;
  border-radius: 25rpx;
  padding: 0 30rpx;
}